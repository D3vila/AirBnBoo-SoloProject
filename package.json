{
  "name": "airbnboo-soloproject",
  "version": "1.0.0",
  "description": "👻AirBnBoo👻",
  "main": "index.js",
  "scripts": {
    "build": "npm install --prefix frontend && npm run build --prefix frontend",
    "install": "npm install --prefix backend && npm install --prefix frontend",
    "postinstall": "npm run build",
    "dev:backend": "npm --prefix backend run start:development",
    "dev:frontend": "npm --prefix frontend run start",
    "sequelize": "npm --prefix backend run sequelize",
    "sequelize-cli": "npm --prefix backend run sequelize-cli",
    "start": "npm --prefix backend run start"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/D3vila/AirBnBoo-SoloProject.git"
  },
